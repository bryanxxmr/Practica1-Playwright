# Environment Configuration
BASE_URL=http://localhost:3000
ENVIRONMENT=staging

# API Configuration (if needed)
API_BASE_URL=http://localhost:3000/api
API_TOKEN=your_api_token_here

# Test Credentials (use GitHub Secrets in CI/CD)
