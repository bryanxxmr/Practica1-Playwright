# Environment Configuration
BASE_URL=https://opensource-demo.orangehrmlive.com
ENVIRONMENT=production

# API Configuration (if needed)
API_BASE_URL=https://opensource-demo.orangehrmlive.com/api
API_TOKEN=your_api_token_here

# Test Credentials (OrangeHRM Demo)
# ⚠️ SECURITY: Never commit these values! Use GitHub Secrets in CI/CD
# Local development: Create .env file (git-ignored) with real test credentials
# GitHub Actions: Use Settings → Secrets and variables → Actions
TEST_USERNAME=admin
TEST_PASSWORD=admin123

# Playwright Options
DEBUG=false
HEADLESS=true
SLOW_MO=0
TIMEOUT=30000

# Logging
LOG_LEVEL=info
